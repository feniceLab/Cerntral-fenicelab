# Fenice Lab — variaveis de ambiente (PLACEHOLDERS — nunca commitar valores reais)

# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE=your-service-role-key-here

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Serviço de Relatórios / Tráfego (services/relatorios — Node, sem deps)
PORT=3030
META_GRAPH_TOKEN=long-lived-user-token-aqui
ADMIN_USER=fenice
ADMIN_PASS=defina-uma-senha-forte
# CLIENTS_DIR=caminho/para/Clientes   # opcional: assets de cliente via /clientes/<slug>/*

# Frontend (apps) — para onde o painel/portal chamam o serviço de tráfego.
# Em dev local com o serviço acima: http://localhost:3030
VITE_TRAFEGO_URL=https://relatorios.fenicelab.com.br
