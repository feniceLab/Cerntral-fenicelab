{
  "$schema": "https://design-tokens.github.io/format/",
  "$meta": {
    "brand": "Fenice Lab",
    "version": "1.0.0",
    "updated": "2026-06",
    "note": "Fonte única de tokens da marca Fenice. Espelha colors_and_type.css (vars --fen-*). Paleta terrosa — zero azul, zero dourado."
  },

  "color": {
    "brand": {
      "terra":      { "value": "#B23A2E", "comment": "primária — marca, ação principal" },
      "terraHover": { "value": "#952E24" },
      "terraPress": { "value": "#76241C", "comment": "press / texto sobre claro" },
      "terraTint":  { "value": "#F6EAE7", "comment": "fundo suave / chip" },
      "cotta":      { "value": "#CC7A4D", "comment": "acento / terracota" },
      "cottaDeep":  { "value": "#97512E", "comment": "kicker / acento sobre claro" }
    },
    "neutral": {
      "avorio":   { "value": "#F3ECE2", "comment": "fundo base (marfim)" },
      "argilla":  { "value": "#E6DAC8", "comment": "borda / divisor" },
      "caffe":    { "value": "#2A211C", "comment": "tinta / texto primário / sidebar" },
      "nero":     { "value": "#160F0B", "comment": "tinta máxima" },
      "surface":  { "value": "#FFFFFF", "comment": "card / superfície elevada" },
      "surface2": { "value": "#FBF7F1", "comment": "superfície sutil / input desabilitado" },
      "muted":    { "value": "#8A7D6F", "comment": "texto secundário / meta" }
    },
    "semantic": {
      "primary":    { "value": "{color.brand.terra}" },
      "accent":     { "value": "{color.brand.cotta}" },
      "bg":         { "value": "{color.neutral.avorio}" },
      "text":       { "value": "{color.neutral.caffe}" },
      "textMuted":  { "value": "{color.neutral.muted}" },
      "border":     { "value": "{color.neutral.argilla}" },
      "success":    { "value": "#5E7A4F", "comment": "verde-oliva" },
      "successBg":  { "value": "#EEF3E9" },
      "warning":    { "value": "#CC7A4D", "comment": "terracota" },
      "warningBg":  { "value": "#FBEFE4" },
      "danger":     { "value": "#B23A2E", "comment": "terra" },
      "dangerBg":   { "value": "#F6EAE7" },
      "info":       { "value": "#6E5A48", "comment": "marrom morno — sem azul" },
      "infoBg":     { "value": "#F1ECE5" }
    },
    "scale": {
      "terra": {
        "50":  { "value": "#F6EAE7" }, "100": { "value": "#EBCEC8" }, "200": { "value": "#DCA89E" },
        "300": { "value": "#CC8275" }, "400": { "value": "#BF5A4A" }, "500": { "value": "#B23A2E" },
        "600": { "value": "#952E24" }, "700": { "value": "#76241C" }, "800": { "value": "#551A14" }, "900": { "value": "#34100C" }
      },
      "neutral": {
        "50":  { "value": "#FBF7F1" }, "100": { "value": "#F3ECE2" }, "200": { "value": "#E6DAC8" },
        "300": { "value": "#C9BBA6" }, "400": { "value": "#A89A88" }, "500": { "value": "#8A7D6F" },
        "700": { "value": "#564636" }, "800": { "value": "#2A211C" }, "900": { "value": "#160F0B" }
      }
    },
    "gradient": {
      "flame":   { "value": "linear-gradient(135deg, #B23A2E 0%, #CC7A4D 100%)", "comment": "fogo — só ação principal e marca" },
      "flameV":  { "value": "linear-gradient(0deg, #952E24 0%, #B23A2E 50%, #CC7A4D 100%)" }
    }
  },

  "font": {
    "family": {
      "display": { "value": "'Fraunces', Georgia, serif", "comment": "títulos / números de destaque / wordmark" },
      "body":    { "value": "'Inter', system-ui, -apple-system, sans-serif", "comment": "corpo + UI" },
      "mono":    { "value": "'JetBrains Mono', ui-monospace, monospace", "comment": "código / dados tabulares" }
    },
    "weight": {
      "regular": { "value": 400 }, "medium": { "value": 500 }, "semibold": { "value": 600 },
      "bold": { "value": 700 }, "black": { "value": 900, "comment": "Fraunces display / wordmark" }
    },
    "size": {
      "display": { "value": "62px", "lineHeight": "1.0",  "letterSpacing": "-0.02em" },
      "h1":      { "value": "36px", "lineHeight": "1.05", "letterSpacing": "-0.015em" },
      "h2":      { "value": "34px", "lineHeight": "1.08", "letterSpacing": "-0.01em" },
      "h3":      { "value": "20px", "lineHeight": "1.2" },
      "lead":    { "value": "17px", "lineHeight": "1.55" },
      "body":    { "value": "15px", "lineHeight": "1.6" },
      "label":   { "value": "13px", "lineHeight": "1.3" },
      "caption": { "value": "11px", "lineHeight": "1.0", "letterSpacing": "0.08em", "transform": "uppercase" },
      "kicker":  { "value": "11px", "lineHeight": "1.0", "letterSpacing": "0.22em", "transform": "uppercase" },
      "mono":    { "value": "13px" }
    }
  },

  "space": {
    "1": { "value": "4px" },  "2": { "value": "8px" },  "3": { "value": "12px" }, "4": { "value": "16px" },
    "5": { "value": "24px" }, "6": { "value": "32px" }, "7": { "value": "48px" }, "8": { "value": "64px" },
    "$base": { "value": "4px", "comment": "escala 4pt" }
  },

  "radius": {
    "sm":   { "value": "8px" },
    "md":   { "value": "12px", "comment": "padrão de card/botão/input" },
    "lg":   { "value": "16px" },
    "xl":   { "value": "24px" },
    "pill": { "value": "999px" }
  },

  "shadow": {
    "sm": { "value": "0 1px 3px rgba(42,33,28,0.10)" },
    "md": { "value": "0 6px 18px rgba(42,33,28,0.12)", "comment": "elevação de cards" },
    "lg": { "value": "0 16px 40px rgba(42,33,28,0.18)" },
    "ring": { "value": "0 0 0 3px rgba(204,122,77,0.5)", "comment": "anel de foco terracota" }
  },

  "motion": {
    "ease":      { "value": "cubic-bezier(0.2, 0.7, 0.3, 1)" },
    "duration":  { "value": "150ms", "comment": "UI" },
    "durationLg":{ "value": "320ms", "comment": "entradas / overlays" }
  },

  "layout": {
    "container": { "value": "1200px" },
    "gutter":    { "value": "24px" },
    "columns":   { "value": 12 }
  }
}
